{
  "name": "Leptos Portfolio",
  "image": "mcr.microsoft.com/devcontainers/rust:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates"
      ]
    }
  },
  "postCreateCommand": "rustup target add wasm32-unknown-unknown && cargo install trunk cargo-generate",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Leptos Dev Server",
      "onAutoForward": "notify"
    }
  }
}
